# Copy to .env.local and fill in. Both are read server-side only.
#
# Resend — waitlist signups.
# A FULL ACCESS key is required: the waitlist writes contacts (Resend retired
# Audiences in 2025; contacts are global + grouped by segments), and send-only
# keys cannot write contacts. Create at https://resend.com → API Keys.
RESEND_API_KEY=

# The "Vestige launch waitlist" segment id (Resend → Contacts → Segments).
# The launch broadcast targets this segment.
RESEND_WAITLIST_SEGMENT_ID=

# OPTIONAL — key for signing welcome-email unsubscribe links (the /unsubscribe
# one-click flow). Defaults to RESEND_API_KEY if unset, so unsubscribe works
# out of the box. Set a dedicated value (any long random string) if you'd rather
# existing unsubscribe links keep working across a Resend API-key rotation.
UNSUBSCRIBE_SECRET=

# Supabase (PROD) — mirror waitlist signups into our own DB (waitlist_subscribers)
# so the list is owned + sendable + measurable from the bunker. Both server-only.
# The anon key is public/safe. Until both are set, the mirror write is a no-op
# (Resend remains the primary capture).
SUPABASE_URL=https://ujbnupjrbroskzwaeulj.supabase.co
SUPABASE_ANON_KEY=
