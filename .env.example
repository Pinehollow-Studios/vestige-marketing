# Copy to .env.local and fill in. Both are read server-side only.
#
# Resend — waitlist signups.
# A FULL ACCESS key is required: the waitlist writes contacts (Resend retired
# Audiences in 2025; contacts are global + grouped by segments), and send-only
# keys cannot write contacts. Create at https://resend.com → API Keys.
RESEND_API_KEY=

# The "Vestige launch waitlist" segment id (Resend → Contacts → Segments).
# The launch broadcast targets this segment.
RESEND_WAITLIST_SEGMENT_ID=
